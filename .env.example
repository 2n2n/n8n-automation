# PostgreSQL Configuration
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change-me-to-strong-password
POSTGRES_DB=n8n

# n8n Encryption Key (generate a long random string - NEVER change after first run!)
# You can generate one with: openssl rand -base64 32
N8N_ENCRYPTION_KEY=change-me-to-long-random-string-min-32-chars

# n8n Basic Authentication
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me-to-strong-password

# n8n Host Configuration
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http

# Timezone (optional)
TZ=America/New_York
